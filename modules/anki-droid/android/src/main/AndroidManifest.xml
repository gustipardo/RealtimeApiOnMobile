<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Required to read AnkiDroid flashcard data via ContentProvider -->
  <uses-permission android:name="com.ichi2.anki.permission.READ_WRITE_DATABASE" />

  <!-- Query for AnkiDroid package (required for Android 11+) -->
  <queries>
    <package android:name="com.ichi2.anki" />
  </queries>
</manifest>
